# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Groq API Key (Free LLM) ───────────────────────────────────
#  Sign up at https://console.groq.com/ – completely free tier.
GROQ_API_KEY=your_groq_api_key_here

# ── Defaults ──────────────────────────────────────────────────
#  Recommended free models: llama-3.1-8b-instant (fastest) | llama-3.3-70b-versatile (smartest)
GROQ_MODEL=llama-3.1-8b-instant

# ── Whisper Model Size (via Groq API) ─────────────────────────
#  Options: whisper-large-v3-turbo | whisper-large-v3 | distil-whisper-large-v3-en
#  'whisper-large-v3-turbo' is the best balance of speed and accuracy (recommended).
WHISPER_MODEL=whisper-large-v3-turbo

# ── Assistant Personality ─────────────────────────────────────
#  The display name the assistant uses when greeting users.
ASSISTANT_NAME=Fury AI

# ── Text-to-Speech (edge-tts) ──────────────────────────────────────────
#  Voice: run `edge-tts --list-voices` to see all options.
#  Popular: en-US-AriaNeural | en-US-GuyNeural | en-GB-SoniaNeural
TTS_VOICE=en-US-AriaNeural

#  Speed: "+0%" = normal | "+30%" = faster | "+50%" = fast
#  Negative values slow it down: "-20%" = slower
TTS_RATE=-50%

# ── Supabase (Auth + Chat History) ────────────────────────────
#  Create a free project at https://supabase.com
#  Find these in: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Email Service (Resend) ────────────────────────────────────
#  Get a free API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here

