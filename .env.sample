# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in your values.
#  Never commit the real `.env` file to version control!
# ─────────────────────────────────────────────────────────────

# ── Telegram Bot Token ────────────────────────────────────────
#  Get yours from @BotFather on Telegram (it's free).
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Groq API Key (Free LLM) ───────────────────────────────────
#  Sign up at https://console.groq.com/ – completely free tier.
GROQ_API_KEY=your_groq_api_key_here

# ── Defaults ──────────────────────────────────────────────────
#  Recommended free models: llama-3.3-70b-versatile | llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# ── Whisper Model Size (via Groq API) ─────────────────────────
#  Options: whisper-large-v3-turbo | whisper-large-v3 | distil-whisper-large-v3-en
#  'whisper-large-v3-turbo' is the best balance of speed and accuracy (recommended).
WHISPER_MODEL=whisper-large-v3-turbo

# ── Assistant Personality ─────────────────────────────────────
#  The display name the assistant uses when greeting users.
ASSISTANT_NAME=Fury AI
